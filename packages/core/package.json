{
  "name": "@opendockit/core",
  "version": "0.1.0",
  "description": "Shared OOXML infrastructure: OPC, DrawingML, themes, colors, fonts, geometry",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./opc": {
      "types": "./dist/opc/index.d.ts",
      "import": "./dist/opc/index.js"
    },
    "./drawingml": {
      "types": "./dist/drawingml/index.d.ts",
      "import": "./dist/drawingml/index.js"
    },
    "./drawingml/renderer": {
      "types": "./dist/drawingml/renderer/index.d.ts",
      "import": "./dist/drawingml/renderer/index.js"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme/index.js"
    },
    "./ir": {
      "types": "./dist/ir/index.d.ts",
      "import": "./dist/ir/index.js"
    },
    "./units": {
      "types": "./dist/units/index.d.ts",
      "import": "./dist/units/index.js"
    },
    "./capability": {
      "types": "./dist/capability/index.d.ts",
      "import": "./dist/capability/index.js"
    },
    "./font": {
      "types": "./dist/font/index.d.ts",
      "import": "./dist/font/index.js"
    },
    "./font/data/metrics-bundle": {
      "types": "./dist/font/data/metrics-bundle.d.ts",
      "import": "./dist/font/data/metrics-bundle.js"
    },
    "./media": {
      "types": "./dist/media/index.d.ts",
      "import": "./dist/media/index.js"
    },
    "./wasm": {
      "types": "./dist/wasm/index.d.ts",
      "import": "./dist/wasm/index.js"
    },
    "./diagnostics": {
      "types": "./dist/diagnostics/index.d.ts",
      "import": "./dist/diagnostics/index.js"
    },
    "./edit": {
      "types": "./dist/edit/index.d.ts",
      "import": "./dist/edit/index.js"
    },
    "./parser": {
      "types": "./dist/parser/index.d.ts",
      "import": "./dist/parser/index.js"
    },
    "./renderer": {
      "types": "./dist/renderer/index.d.ts",
      "import": "./dist/renderer/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.8.11",
    "fast-xml-parser": "^4.5.0",
    "jszip": "^3.10.0"
  },
  "peerDependencies": {
    "@opendockit/fonts": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@opendockit/fonts": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
